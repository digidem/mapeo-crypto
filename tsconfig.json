{
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "checkJs": false,
    "declaration": true,
    "declarationDir": "dist",
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "lib": ["es2022", "dom"],
    "moduleResolution": "node",
    "noImplicitAny": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "target": "es2019",
    "typeRoots": [
      "node_modules/@types",
      "./types"
    ],
    "paths": {
      "@hyperswarm/secret-stream": [
        "./node_modules/@digidem/types/vendor/@hyperswarm/secret-stream/index.d.ts"
      ],
      "*": ["./node_modules/@digidem/types/vendor/*/index.d.ts"]
    }
  },
  "include": ["index.js"],
  "exclude": ["node_modules", "dist"]
}
